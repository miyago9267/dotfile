{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4",
  "default_agent": "studio-monika",
  "share": "disabled",
  "instructions": [
    "AGENTS.md"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": false,
      "timeout": 10000
    }
  },
  "permission": {
    "task": "allow",
    "skill": {
      "safe-ops": "allow",
      "search-discipline": "allow",
      "path-aware": "allow",
      "efficiency": "allow",
      "markdown-lint": "allow",
      "tdd": "allow",
      "*": "deny"
    }
  }
}
