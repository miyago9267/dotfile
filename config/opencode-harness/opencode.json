{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "monika-large",
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "pty-bridge": {
      "type": "local",
      "command": [
        "/Users/miyago/.bun/bin/bun",
        "run",
        "/Users/miyago/dotfile/config/ai/claude/mcp/pty-bridge/index.ts"
      ],
      "enabled": false
    },
    "sentry:sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": false
    }
  }
}
