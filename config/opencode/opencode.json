{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4",
  "default_agent": "monika",
  "share": "disabled",
  "enabled_providers": [
    "openai",
    "deepseek",
    "google",
    "github-copilot",
    "opencode",
    "aluo"
  ],
  "provider": {
    "google": {
      "options": {
        "apiKey": "{file:~/.config/opencode/secrets/gemini-api-key}"
      },
      "models": {
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview"
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro"
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash"
        },
        "gemini-2.0-flash": {
          "name": "Gemini 2.0 Flash"
        }
      }
    },
    "aluo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Aluo API",
      "options": {
        "baseURL": "https://ai-api.aluo.work/v1",
        "apiKey": "{file:~/.config/opencode/secrets/aluo-api-key}"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5 (Aluo bridge)"
        },
        "gpt-5.4": {
          "name": "GPT-5.4 (Aluo bridge)"
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 40000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".direnv/**",
      ".venv/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "coverage/**",
      ".turbo/**",
      ".next/**",
      ".nuxt/**",
      ".cache/**",
      "tmp/**",
      "temp/**",
      "logs/**",
      "*.log",
      "secrets/**",
      "**/.obsidian/**",
      "**/.trash/**",
      "**/.DS_Store"
    ]
  },
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "task": "deny",
    "skill": {
      "safe-ops": "allow",
      "git-workflow": "allow",
      "no-ai-attribution": "allow",
      "search-discipline": "allow",
      "path-aware": "allow",
      "efficiency": "allow",
      "markdown-lint": "allow",
      "tdd": "allow",
      "ask-tty": "deny",
      "auto-docs": "deny",
      "cicd-watch": "deny",
      "strategic-compact": "deny",
      "*": "deny"
    }
  }
}
