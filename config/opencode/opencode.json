{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4",
  "default_agent": "monika",
  "share": "disabled",
  "enabled_providers": [
    "openai",
    "deepseek",
    "github-copilot",
    "opencode"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 40000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".direnv/**",
      ".venv/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "coverage/**",
      ".turbo/**",
      ".next/**",
      ".nuxt/**",
      ".cache/**",
      "tmp/**",
      "temp/**",
      "logs/**",
      "*.log",
      "secrets/**",
      "**/.obsidian/**",
      "**/.trash/**",
      "**/.DS_Store"
    ]
  },
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "task": "deny",
    "skill": {
      "safe-ops": "allow",
      "git-workflow": "allow",
      "no-ai-attribution": "allow",
      "search-discipline": "allow",
      "path-aware": "allow",
      "efficiency": "allow",
      "markdown-lint": "allow",
      "tdd": "allow",
      "ask-tty": "deny",
      "auto-docs": "deny",
      "cicd-watch": "deny",
      "strategic-compact": "deny",
      "*": "deny"
    }
  }
}
