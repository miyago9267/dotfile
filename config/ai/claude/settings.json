{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "25"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "mcp__claude_ai_Canva__generate-design",
      "mcp__claude_ai_Canva__create-design-from-candidate",
      "mcp__claude_ai_Canva__export-design",
      "Bash(echo \"deleted: $?\")",
      "Bash(/bin/ls /Users/miyago/Project/Code/Web/RiceCall/RiceCallAdminPanel/app/components/ui/UuidCell.vue)",
      "Bash(/bin/ls -1)",
      "Bash(/bin/ls -1 line_bot_updated/)"
    ],
    "deny": [
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(sudo rm *)",
      "Bash(sudo dd *)",
      "Bash(chmod -R 777 *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(rmdir *)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git clean *)",
      "Bash(pkill *)",
      "Bash(kill *)"
    ],
    "additionalDirectories": [
      "/Users/miyago/.claude",
      "/Users/miyago/Project/Code/ITRD/pms/.claude",
      "/Users/miyago/Project/Note/knowledge-base"
    ]
  },
  "hooks": {
    "InstructionsLoaded": [
      {
        "matcher": "session_start|include|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/instructions-loaded-reminder.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/auto-yes.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/git-add-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/commit-attribution-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/ops-write-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/skills/strategic-compact/suggest-compact.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/cwd-context.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/tty-respond.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/pre-compact-instructions.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/post-compact-reminder.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-tool-use-format.sh",
            "timeout": 30,
            "statusMessage": "Auto format & lint..."
          },
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/markdown-lint-fix.sh",
            "timeout": 15,
            "statusMessage": "markdown lint fix..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/git-push-ci-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/subagent-stop-reminder.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/task-completed-reminder.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/persona-reminder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/dotfile/config/ai/claude/hooks/sre-inventory-stale-check.sh",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n | tail -1 | cut -f2-); exec node \"${plugin_dir}dist/index.js\"'"
  },
  "enabledPlugins": {
    "gitlab@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "dev-discipline@dev-discipline": true,
    "swift-lsp@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "dev-discipline": {
      "source": {
        "source": "github",
        "repo": "miyago9267/dev-discipline"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "effortLevel": "medium",
  "theme": "dark-ansi",
  "model": "claude-fable-5"
}
