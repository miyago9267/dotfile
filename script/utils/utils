#!/bin/bash
# 顯示 utils 工具集的快速說明

Y='\033[1;33m'
G='\033[1;32m'
C='\033[1;36m'
N='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

get_desc() {
  case "$1" in
    cfupdate.py)  echo "CloudFlare DNS 動態更新（需設定 API token）" ;;
    extract)      echo "智能解壓縮（tar/zip/rar/7z/bz2...）" ;;
    gq)           echo "git add + commit + push 一步到位" ;;
    utils)        echo "顯示這份說明" ;;
    hs)           echo "快速 HTTP server" ;;
    init-project) echo "專案初始化（Python/Node/Go）" ;;
    jp)           echo "JSON 格式化" ;;
    pf)           echo "查找佔用 port 的 process" ;;
    qb)           echo "快速備份（加時間戳）" ;;
    qn)           echo "快速筆記" ;;
    runcpp.sh)    echo "C++ 編譯執行（支援 GDB）" ;;
    sec)          echo "Secret 管理（init/edit/show/list/push/export/import/reload/status）" ;;
    si)           echo "系統資訊（OS, CPU, RAM, Disk, Network）" ;;
    *)            sed -n '2,3s/^#\s*//p' "$SCRIPT_DIR/$1" 2>/dev/null | head -1 ;;
  esac
}

get_usage() {
  case "$1" in
    cfupdate.py)  echo "cfupdate.py" ;;
    extract)      echo "extract <file>" ;;
    gq)           echo "gq \"commit message\"" ;;
    utils)        echo "utils [cmd]" ;;
    hs)           echo "hs [port]  (default: 8000)" ;;
    init-project) echo "init-project" ;;
    jp)           echo "jp '{\"a\":1}' | curl ... | jp" ;;
    pf)           echo "pf <port>" ;;
    qb)           echo "qb <file-or-dir>" ;;
    qn)           echo "qn add \"text\" | qn list | qn search <keyword>" ;;
    runcpp.sh)    echo "runcpp.sh <file.cpp>" ;;
    sec)          echo "sec <init|edit|show|list|push|export|import|reload|status>" ;;
    si)           echo "si" ;;
    *)            echo "$1" ;;
  esac
}

printf "${C}Utils -- 短指令工具集${N}\n\n"

# 帶參數：顯示特定指令詳細用法
if [ -n "$1" ]; then
  printf "${G}%s${N} -- %s\n" "$1" "$(get_desc "$1")"
  printf "${Y}Usage:${N} %s\n" "$(get_usage "$1")"
  exit 0
fi

# 找最長名稱用來對齊
max_len=0
for f in "$SCRIPT_DIR"/*; do
  [ -f "$f" ] || continue
  name="$(basename "$f")"
  [ "$name" = "README.md" ] && continue
  [ ${#name} -gt $max_len ] && max_len=${#name}
done

# 列出所有指令
for f in "$SCRIPT_DIR"/*; do
  [ -f "$f" ] || continue
  name="$(basename "$f")"
  [ "$name" = "README.md" ] && continue
  printf "  ${G}%-${max_len}s${N}  %s\n" "$name" "$(get_desc "$name")"
done

printf "\n${C}Tip:${N} utils <cmd> 查看特定指令用法\n"
