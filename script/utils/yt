#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  yt [options] URL [yt-dlp options...]

Modes:
  yt URL              Download Premiere-friendly mp4 video
  yt -v URL           Download Premiere-friendly mp4 video
  yt -a URL           Download m4a audio
  yt --mp3 URL        Download audio and convert to mp3
  yt --m4a URL        Download audio and convert to m4a
  yt --webm URL       Download raw highest-quality video

All other arguments are passed through to yt-dlp.
EOF
}

mode="video"
audio_format="m4a"
video_format="premiere"
args=()

while (($#)); do
  case "$1" in
    -a|--audio)
      mode="audio"
      shift
      ;;
    -v|--video)
      mode="video"
      shift
      ;;
    --webm|--raw)
      mode="video"
      video_format="raw"
      shift
      ;;
    --mp3)
      mode="audio"
      audio_format="mp3"
      shift
      ;;
    --m4a)
      mode="audio"
      audio_format="m4a"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      args+=("$@")
      break
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if ! command -v yt-dlp >/dev/null 2>&1; then
  printf 'yt: yt-dlp not found in PATH\n' >&2
  exit 127
fi

if ((${#args[@]} == 0)); then
  usage >&2
  exit 2
fi

common_args=(
  --no-mtime
  -o '%(title).200s [%(id)s].%(ext)s'
)

case "$mode" in
  audio)
    exec yt-dlp \
      -f 'bestaudio/best' \
      -x \
      --audio-format "$audio_format" \
      "${common_args[@]}" \
      "${args[@]}"
    ;;
  video)
    if [ "$video_format" = "raw" ]; then
      exec yt-dlp \
        -f 'bestvideo*+bestaudio/best' \
        "${common_args[@]}" \
        "${args[@]}"
    fi

    exec yt-dlp \
      -f 'bv*[ext=mp4][vcodec^=avc1]+ba[ext=m4a]/b[ext=mp4][vcodec^=avc1]/bv*+ba/b' \
      --merge-output-format mp4 \
      --recode-video mp4 \
      "${common_args[@]}" \
      "${args[@]}"
    ;;
esac
